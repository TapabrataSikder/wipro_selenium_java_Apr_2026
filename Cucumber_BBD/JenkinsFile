pipeline {
    agent any
 
    tools {
        maven 'Maven3'
    }
 
    stages {
 
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/TapabrataSikder/wipro_selenium_java_Apr_2026'
            }
        }
 
        stage('Build') {
            steps {
                bat 'mvn clean'
            }
        }
 
        stage('Compile') {
            steps {
                bat 'mvn compile'
            }
        }
 
        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }
 
        stage('Package') {
            steps {
                bat 'mvn package'
            }
        }
    }
 
    post {
        success {
            echo 'Build Successful'
        }
 
        failure {
            echo 'Build Failed'
        }
    }
}