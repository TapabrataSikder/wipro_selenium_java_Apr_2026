pipeline {
    agent any
 
    tools {
        maven 'maven3'
    }
 
    stages {
        // We focus strictly on Cucumber_BBD now

        stage('Build') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn clean'
                }
            }
        }
 
        stage('Compile') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn compile'
                }
            }
        }
 
        stage('Test') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn test'
                }
            }
        }
 
        stage('Package') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn package'
                }
            }
        }
    }
 
    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}