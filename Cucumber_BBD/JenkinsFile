pipeline {
    agent any
 
    tools {
        maven 'maven3'
    }
 
    stages {
        // Notice: We completely removed the manual Git checkout stage 
        // because Jenkins already auto-downloads the whole repository!

        stage('Build Dependency') {
            steps {
                // Match the exact folder name from your GitHub repository
                dir('TestNG_Selenium_pract') {
                    bat 'mvn clean install'
                }
            }
        }
 
        stage('Build Main Project') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn clean'
                }
            }
        }
 
        stage('Compile') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn compile'
                }
            }
        }
 
        stage('Test') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn test'
                }
            }
        }
 
        stage('Package') {
            steps {
                dir('Cucumber_BBD') {
                    bat 'mvn package'
                }
            }
        }
    }
 
    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}